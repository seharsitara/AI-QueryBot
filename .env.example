# ============================================================
# OpenAI
# ============================================================
# Used for both chat completions (gpt-4o) and embeddings
# (text-embedding-3-small, 1536 dims).
OPENAI_API_KEY=

# ============================================================
# Qdrant (vector DB)
# ============================================================
# For Qdrant Cloud: https://<cluster-id>.<region>.cloud.qdrant.io
# For local Docker: http://localhost:6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=rag-chatbot-docs

# ============================================================
# Supabase
# ============================================================
# Project URL + publishable key are safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Secret key — server-side only. Bypasses RLS. Used by the cron worker
# to claim and process queued docs without an authenticated session.
SUPABASE_SECRET_KEY=sb_secret_your-key

# ============================================================
# Cron worker
# ============================================================
# Shared secret between the Supabase Edge Function (dispatcher) and the
# Next.js /api/cron/process-docs route. Any random long string works.
CRON_SECRET=